# Authentication Token Secret
JWT_SECRET="membrain-strategic-forgetting-secret-99"

# Database Connection URL (Alibaba Cloud ApsaraDB RDS PostgreSQL Instance)
DATABASE_URL="postgresql://postgres:password@localhost:5432/membrain_db?schema=public"

# Alibaba Cloud Qwen configurations
QWEN_API_KEY="your_qwen_api_key"
QWEN_MODEL="qwen-max"
QWEN_EMBEDDING_MODEL="text-embedding-v3"
QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
